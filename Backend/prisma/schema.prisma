generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  username       String?         @unique
  email          String          @unique
  passwordHash   String?
  otp            String?
  otpExpires     DateTime?
  avatar         String?
  provider       String?
  googleId       String?
  facebookId     String?
  globalRating   Int             @default(1200)
  xp             Int             @default(0)
  ratings        Json?
  college        String?
  course         String?
  customField    String?
  dob            DateTime?
  preferredField String          @default("General")
  settings       Json?
  interest       String?
  role           String          @default("user")
  status         String          @default("active")
  dailyStreak    Int             @default(0)
  lastPlayedAt       DateTime?
  lastUsernameChange DateTime?
  publicKey          String?         // E2EE Public Key (JWK)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  hostedSessions     GameSession[]   @relation("UserSessions")
  quizzes            Quiz[]          @relation("UserQuizzes")
  ratingHistory      RatingHistory[]
  
  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")
  sentMessages         Message[]    @relation("SentMessages")
  receivedMessages     Message[]    @relation("ReceivedMessages")

  @@index([email])
  @@index([globalRating(sort: Desc)])
}

model Quiz {
  id          String        @id @default(uuid())
  title       String
  topic       String?
  authorId    String?
  questions   Json
  aiGenerated Boolean       @default(false)
  tags        String[]
  difficulty  String        @default("medium")
  playCount   Int           @default(0)
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  sessions    GameSession[]
  author      User?         @relation("UserQuizzes", fields: [authorId], references: [id])

  @@index([topic])
  @@index([difficulty])
  @@index([playCount(sort: Desc)])
}

model GameSession {
  id            String          @id @default(uuid())
  quizId        String
  hostId        String
  mode          String          @default("battle")
  timerSeconds  Int             @default(30)
  rated         Boolean         @default(true)
  battleType    String?         // 1v1, 2v2, 4v4
  teamScores    Json?           // { teamA: 0, teamB: 0 }
  pin           String          @unique
  status        String          @default("waiting")
  metadata      Json?           // Stores aggregated results like avg accuracy, etc.
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  host          User            @relation("UserSessions", fields: [hostId], references: [id])
  quiz          Quiz            @relation(fields: [quizId], references: [id])
  ratingHistory RatingHistory[]
  answerLogs    AnswerLog[]
}

model AnswerLog {
  id            String      @id @default(uuid())
  sessionId     String
  questionIndex Int
  userId        String?     // Null if player isn't logged in (PIN join)
  playerName    String      // To identify guest players too
  selectedIdx   Int
  isCorrect     Boolean
  timeTaken     Float
  ipAddress     String?
  timestamp     DateTime    @default(now())
  session       GameSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([questionIndex])
}

model RatingHistory {
  id        String      @id @default(uuid())
  userId    String
  gameId    String
  mode      String?
  before    Int?
  after     Int?
  delta     Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  game      GameSession @relation(fields: [gameId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("pending") // "pending", "accepted", "blocked"
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  type       String   @default("text") // "text", "invite"
  metadata   Json?    
  isRead     Boolean  @default(false)
  isEncrypted Boolean  @default(false) // E2EE Flag
  createdAt  DateTime @default(now())
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([createdAt])
}
