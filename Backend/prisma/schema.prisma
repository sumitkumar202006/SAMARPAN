generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  name           String
  username       String?         @unique
  email          String          @unique
  passwordHash   String?
  otp            String?
  otpExpires     DateTime?
  avatar         String?
  avatarFrame    String?         // "none" | "bronze" | "gold" | "diamond" | "champion"
  provider       String?
  googleId       String?
  facebookId     String?
  globalRating   Int             @default(1200)
  xp             Int             @default(0)
  totalWins      Int             @default(0)
  totalLosses    Int             @default(0)
  winStreak      Int             @default(0)   // current win streak
  bestWinStreak  Int             @default(0)   // all-time best win streak
  ratings        Json?
  college        String?
  course         String?
  customField    String?
  dob            DateTime?
  preferredField String          @default("General")
  settings       Json?
  interest       String?
  role           String          @default("user")
  status         String          @default("active")
  dailyStreak    Int             @default(0)
  lastPlayedAt       DateTime?
  lastUsernameChange DateTime?
  publicKey          String?         // E2EE Public Key (JWK)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  hostedSessions     GameSession[]   @relation("UserSessions")
  quizzes            Quiz[]          @relation("UserQuizzes")
  news               News[]          @relation("UserNews")
  ratingHistory      RatingHistory[]
  subscription       Subscription?
  quota              UsageQuota?
  notifications      Notification[]
  tournaments        TournamentParticipant[]

  friendshipsInitiated Friendship[] @relation("UserFriendships")
  friendshipsReceived  Friendship[] @relation("FriendFriendships")
  sentMessages         Message[]    @relation("SentMessages")
  receivedMessages     Message[]    @relation("ReceivedMessages")
  quizReviews          QuizReview[]
  rsvps                EventRsvp[]
  institutionMemberships InstitutionMember[]
  ownedInstitution     Institution? @relation("InstitutionOwner")
  assignments          QuizAssignment[]

  @@index([email])
  @@index([globalRating(sort: Desc)])
}

model Quiz {
  id              String        @id @default(uuid())
  title           String
  topic           String?
  authorId        String?
  questions       Json
  aiGenerated     Boolean       @default(false)
  tags            String[]
  difficulty      String        @default("medium")
  playCount       Int           @default(0)
  isPublished     Boolean       @default(true)
  // Marketplace fields
  isMarketplace   Boolean       @default(false)  // Listed publicly in marketplace
  averageRating   Float         @default(0)      // Avg of QuizReview.rating
  reviewCount     Int           @default(0)
  // Scheduled event support
  scheduledAt     DateTime?     // If set, quiz is a scheduled event
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  sessions        GameSession[]
  author          User?         @relation("UserQuizzes", fields: [authorId], references: [id])
  reviews         QuizReview[]
  eventRsvps      EventRsvp[]

  @@index([topic])
  @@index([difficulty])
  @@index([playCount(sort: Desc)])
  @@index([isMarketplace])
  @@index([scheduledAt])
}

model GameSession {
  id            String          @id @default(uuid())
  quizId        String
  hostId        String
  mode          String          @default("battle")
  timerSeconds  Int             @default(30)
  rated         Boolean         @default(true)
  battleType    String?         // 1v1, 2v2, 4v4
  teamScores    Json?           // { teamA: 0, teamB: 0 }
  pin           String          @unique
  status        String          @default("waiting")
  metadata      Json?           // Stores aggregated results like avg accuracy, etc.
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  host          User            @relation("UserSessions", fields: [hostId], references: [id])
  quiz          Quiz            @relation(fields: [quizId], references: [id])
  ratingHistory RatingHistory[]
  answerLogs    AnswerLog[]
}

model AnswerLog {
  id            String      @id @default(uuid())
  sessionId     String
  questionIndex Int
  userId        String?     // Null if player isn't logged in (PIN join)
  playerName    String      // To identify guest players too
  selectedIdx   Int
  isCorrect     Boolean
  timeTaken     Float
  ipAddress     String?
  timestamp     DateTime    @default(now())
  session       GameSession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([questionIndex])
}

model RatingHistory {
  id        String      @id @default(uuid())
  userId    String
  gameId    String
  mode      String?
  before    Int?
  after     Int?
  delta     Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  game      GameSession @relation(fields: [gameId], references: [id])
  user      User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  friendId  String
  status    String   @default("pending") // "pending", "accepted", "blocked"
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend    User     @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@index([friendId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  type       String   @default("text") // "text", "invite"
  metadata   Json?    
  isRead     Boolean  @default(false)
  isEncrypted Boolean  @default(false) // E2EE Flag
  createdAt  DateTime @default(now())
  
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([createdAt])
}

model News {
  id        String   @id @default(uuid())
  title     String
  content   String
  image     String?
  category  String   @default("General")
  isPinned  Boolean  @default(false)
  authorId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User?    @relation("UserNews", fields: [authorId], references: [id])
}

model SystemConfig {
  key   String @id
  value Json
}

// ─── Subscription & Billing ───────────────────────────────────────────────────

model Subscription {
  id                String   @id @default(uuid())
  userId            String   @unique
  plan              String   @default("free")    // "free" | "pro" | "elite" | "institution"
  status            String   @default("active")  // "active" | "trialing" | "cancelled" | "past_due"
  razorpaySubId     String?  // Razorpay subscription ID
  razorpayCustomerId String? // Razorpay customer ID
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean  @default(false)
  trialEndsAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model UsageQuota {
  id            String   @id @default(uuid())
  userId        String   @unique
  aiGenerations Int      @default(0)  // Used this billing period
  pdfUploads    Int      @default(0)  // Used this billing period
  resetAt       DateTime             // Next monthly reset date
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DeviceTrial {
  id          String   @id @default(uuid())
  fingerprint String   @unique // Device fingerprint hash
  usedAt      DateTime @default(now()) // When trial was activated
  email       String   // Which email used it (audit trail)

  @@index([fingerprint])
}

// ─── Notifications ─────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "friend_request" | "challenge" | "subscription" | "streak" | "match_result" | "system"
  title     String
  message   String
  link      String?  // Optional deep link
  metadata  Json?    // Extra payload (e.g. challengerId, quizId)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
}

// ─── Tournaments ───────────────────────────────────────────────────────────────
model Tournament {
  id           String   @id @default(uuid())
  name         String
  description  String?
  hostId       String
  quizId       String?
  status       String   @default("upcoming") // "upcoming" | "registration" | "running" | "completed"
  maxPlayers   Int      @default(16)
  format       String   @default("single_elimination") // "single_elimination" | "round_robin"
  bracket      Json?    // Bracket state
  startTime    DateTime?
  endTime      DateTime?
  prize        String?  // Prize description
  requiredPlan String?  // null = open to all, "pro" = pro+
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  participants TournamentParticipant[]

  @@index([status])
  @@index([startTime])
}

model TournamentParticipant {
  id            String     @id @default(uuid())
  tournamentId  String
  userId        String
  status        String     @default("registered") // "registered" | "active" | "eliminated" | "winner"
  finalRank     Int?
  registeredAt  DateTime   @default(now())
  tournament    Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

// ─── Quiz Marketplace ──────────────────────────────────────────────────────────
model QuizReview {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  rating    Int      // 1-5 stars
  comment   String?
  createdAt DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([quizId, userId])  // One review per user per quiz
  @@index([quizId])
  @@index([rating])
}

// ─── Scheduled Events ──────────────────────────────────────────────────────────
model ScheduledEvent {
  id           String      @id @default(uuid())
  quizId       String
  hostId       String
  title        String
  description  String?
  scheduledAt  DateTime
  maxPlayers   Int         @default(100)
  isPublic     Boolean     @default(true)
  status       String      @default("upcoming") // "upcoming" | "live" | "ended"
  pin          String?     // Set when event goes live
  recurrence   String?     // null | "daily" | "weekly"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  rsvps        EventRsvp[]

  @@index([scheduledAt])
  @@index([hostId])
  @@index([status])
}

model EventRsvp {
  id        String         @id @default(uuid())
  eventId   String?
  quizId    String?        // Direct quiz RSVP
  userId    String
  createdAt DateTime       @default(now())
  event     ScheduledEvent? @relation(fields: [eventId], references: [id], onDelete: Cascade)
  quiz      Quiz?           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
}

// ─── Institution Dashboard ─────────────────────────────────────────────────────
model Institution {
  id          String              @id @default(uuid())
  name        String
  code        String              @unique  // Join code (e.g. "SKPS-2024")
  ownerId     String              @unique
  logoUrl     String?
  website     String?
  plan        String              @default("institution")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation("InstitutionOwner", fields: [ownerId], references: [id])
  members     InstitutionMember[]
  assignments QuizAssignment[]

  @@index([code])
  @@index([ownerId])
}

model InstitutionMember {
  id            String      @id @default(uuid())
  institutionId String
  userId        String
  role          String      @default("student") // "student" | "teacher" | "admin"
  joinedAt      DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@index([institutionId])
  @@index([userId])
}

model QuizAssignment {
  id            String      @id @default(uuid())
  institutionId String
  quizId        String
  assignedById  String
  title         String?
  dueAt         DateTime?
  createdAt     DateTime    @default(now())
  institution   Institution @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  assignedBy    User        @relation(fields: [assignedById], references: [id])

  @@index([institutionId])
  @@index([dueAt])
}
